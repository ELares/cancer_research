# OpenAlex API (polite pool - higher rate limits)
OPENALEX_EMAIL=your-email@example.com
OPENALEX_API_KEY=your-openalex-api-key

# Semantic Scholar API (free key for higher rate limits)
# Apply at: https://www.semanticscholar.org/product/api#api-key-form
SEMANTIC_SCHOLAR_API_KEY=

# PubMed/NCBI E-utilities (free key for 10 req/s instead of 3)
# Register at: https://www.ncbi.nlm.nih.gov/account/
NCBI_API_KEY=

# CORE API (required - free key)
# Register at: https://core.ac.uk/services/api
CORE_API_KEY=
